# PostgreSQL
POSTGRES_IMAGE=postgres:16-alpine
POSTGRES_CONTAINER_NAME=macrotrack-api-postgres
POSTGRES_DB=macrotrack_db
POSTGRES_USER=macrotrack_user
POSTGRES_PASSWORD=macrotrack_pass
POSTGRES_PORT=23005

# API
API_CONTAINER_NAME=macrotrack-api
API_PORT=8080

# Spring Boot
SPRING_PROFILES_ACTIVE=dev
